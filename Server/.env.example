NODE_ENV=development
ENABLE_SMS_OTP=false

# Twilio SMS credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Use either a Twilio phone number OR a Messaging Service SID.
# Messaging Service SIDs start with MG. A Verify Service SID (VA...) will not work here.
TWILIO_FROM_NUMBER=+15551234567
TWILIO_MESSAGING_SERVICE_SID=

# Country code used when formatting local mobile numbers.
OTP_PHONE_COUNTRY_CODE=91

# Brevo API key for API requests such as email and transactional SMS.
# Use a Brevo API key that starts with "xkeysib-".
# Do not use the SMTP key that starts with "xsmtpsib-".
BREVO_API_KEY=xkeysib-your-brevo-api-key

# Optional: legacy Brevo SMS API key. Twilio is preferred for SMS in this project now.
BREVO_SMS_API_KEY=

# Email sender used by Brevo email API
BREVO_EMAIL=no-reply@example.com

# Sender ID shown in SMS. Keep it short; Brevo allows up to 11 alphanumeric chars.
BREVO_SMS_SENDER=SalonHub

# Groq API (free, no billing required) — get key at https://console.groq.com
GROQ_API_KEY=groq-api-key
